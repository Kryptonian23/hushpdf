# Public browser configuration. These values identify public AWS resources;
# they are not secrets. Never put Stripe or Cognito client secrets here.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_COGNITO_USER_POOL_ID=
NEXT_PUBLIC_COGNITO_USER_POOL_CLIENT_ID=
NEXT_PUBLIC_COGNITO_DOMAIN=
NEXT_PUBLIC_BILLING_API_URL=

# Rewarded advertising remains disabled until the production consent flow and
# provider approval are complete.
NEXT_PUBLIC_REWARDED_ACCESS_ENABLED=false
