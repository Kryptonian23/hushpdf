{
    "manifest_version": 3,
    "name": "HushPDF - Private PDF Tools",
    "version": "1.0.0",
    "description": "Private, zero-upload PDF tools that process files directly on your device.",
    "author": "HushPDF contributors",
    "icons": {
        "16": "icons/icon16.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    },
    "action": {
        "default_popup": "popup.html",
        "default_icon": {
            "16": "icons/icon16.png",
            "48": "icons/icon48.png",
            "128": "icons/icon128.png"
        },
        "default_title": "HushPDF - Private PDF Tools"
    },
    "background": {
        "service_worker": "background.js"
    },
    "permissions": [
        "contextMenus"
    ]
}
